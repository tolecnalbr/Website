---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).sort(
    (a, b) => a.data.date.valueOf() - b.data.date.valueOf()
  );
  return posts.map((post, index) => ({
    params: { slug: post.id },
    props: {
      post,
      prevPost: index > 0 ? posts[index - 1] : null,
      nextPost: index < posts.length - 1 ? posts[index + 1] : null,
    },
  }));
}

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await render(post);

const formattedDate = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Reading time estimate
const body = post.body ?? '';
const wordCount = body.split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 230));

const base = import.meta.env.BASE_URL;

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": post.data.date.toISOString(),
  "author": {
    "@type": "Person",
    "name": "Lancelot",
  },
  "url": new URL(`${base}blog/${post.id}`, Astro.site).href,
});
---

<BaseLayout title={`${post.data.title} - Lancelot`} description={post.data.description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd} />
  </Fragment>
  <main id="main-content" class="container">
    <article class="blog-post">
      <header>
        <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
        <span class="reading-time">&middot; {readingTime} min read</span>
        <h1>{post.data.title}</h1>
      </header>
      <div class="prose">
        <Content />
      </div>
      <footer>
        <nav class="post-nav" aria-label="Blog post navigation">
          <div class="post-nav-prev">
            {prevPost && (
              <a href={`${base}blog/${prevPost.id}`}>
                &larr; {prevPost.data.title}
              </a>
            )}
          </div>
          <div class="post-nav-next">
            {nextPost && (
              <a href={`${base}blog/${nextPost.id}`}>
                {nextPost.data.title} &rarr;
              </a>
            )}
          </div>
        </nav>
        <div class="back-link">
          <a href={`${base}blog`}>&larr; All posts</a>
        </div>
      </footer>
    </article>
  </main>
</BaseLayout>

<style>
  .blog-post header {
    padding: 3rem 0 2rem;
  }

  .blog-post time {
    font-size: 0.85rem;
    color: var(--color-text-light);
  }

  .reading-time {
    font-size: 0.85rem;
    color: var(--color-text-light);
  }

  .blog-post h1 {
    font-size: 1.8rem;
    margin-top: 0.5rem;
  }

  .prose {
    padding-bottom: 2rem;
  }

  .prose :global(h2) {
    font-size: 1.4rem;
    margin: 2rem 0 0.75rem;
  }

  .prose :global(p) {
    margin-bottom: 1.25rem;
  }

  .prose :global(mark) {
    background: linear-gradient(180deg, transparent 50%, rgba(255, 243, 0, 0.45) 50%, rgba(255, 243, 0, 0.45) 88%, transparent 88%);
    color: inherit;
    padding: 0 0.1em;
  }

  .prose :global(code) {
    background: #f0f0f0;
    padding: 0.15em 0.35em;
    border-radius: 3px;
    font-size: 0.9em;
  }

  .prose :global(pre) {
    background: #1a1a1a;
    color: #fafafa;
    padding: 1rem;
    border-radius: 6px;
    overflow-x: auto;
    margin-bottom: 1.25rem;
  }

  footer {
    padding: 2rem 0;
    border-top: 1px solid var(--color-border);
  }

  .post-nav {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .post-nav a {
    font-size: 0.9rem;
    color: var(--color-text-light);
  }

  .post-nav a:hover {
    color: var(--color-text);
  }

  .post-nav-next {
    text-align: right;
    margin-left: auto;
  }

  .back-link a {
    font-size: 0.9rem;
    color: var(--color-text-light);
  }
</style>
