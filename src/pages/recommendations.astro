---
import BaseLayout from '../layouts/BaseLayout.astro';

import books from '../content/recommendations/books.json';
import movies from '../content/recommendations/movies.json';
import quotes from '../content/recommendations/quotes.json';

function renderStars(rating: number | null): string {
  if (rating === null) return '';
  return '★'.repeat(rating) + '☆'.repeat(5 - rating);
}
---

<BaseLayout title="Recommendations — Lancelot" description="Books, movies, and quotes I recommend">
  <main id="main-content" class="container">
    <article class="page-content">
      <h1>Recommendations</h1>

      <section class="rec-section">
        <h2>Quotes</h2>
        {quotes.map((q) => (
          <div class="rec-item quote-item">
            <blockquote>&ldquo;{q.text}&rdquo;</blockquote>
            <p class="quote-author">&mdash; {q.author}</p>
            {q.comment && <p class="comment">{q.comment}</p>}
          </div>
        ))}
      </section>

      <section class="rec-section">
        <h2>Books</h2>
        {books.map((b) => (
          <div class="rec-item">
            <div class="rec-header">
              <span class="rec-title">{b.title}</span>
              <span class={`status ${b.status === 'read' ? 'status-done' : 'status-pending'}`}>
                {b.status}
              </span>
            </div>
            <p class="rec-meta">{b.author}</p>
            {b.rating !== null && <p class="rating">{renderStars(b.rating)}</p>}
            {b.comment && <p class="comment">{b.comment}</p>}
          </div>
        ))}
      </section>

      <section class="rec-section">
        <h2>Movies</h2>
        {movies.map((m) => (
          <div class="rec-item">
            <div class="rec-header">
              <span class="rec-title">{m.title}</span>
              <span class={`status ${m.status === 'watched' ? 'status-done' : 'status-pending'}`}>
                {m.status}
              </span>
            </div>
            <p class="rec-meta">{m.year}</p>
            {m.rating !== null && <p class="rating">{renderStars(m.rating)}</p>}
            {m.comment && <p class="comment">{m.comment}</p>}
          </div>
        ))}
      </section>
    </article>
  </main>
</BaseLayout>

<style>
  .page-content {
    padding: 3rem 0;
  }

  .page-content h1 {
    font-size: 1.8rem;
    margin-bottom: 2rem;
  }

  h2 {
    font-size: 1.3rem;
    margin-bottom: 1rem;
  }

  .rec-section {
    margin-bottom: 3rem;
  }

  .rec-item {
    margin-bottom: 1.5rem;
  }

  .rec-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .rec-title {
    font-weight: 600;
    font-size: 1.05rem;
  }

  .status {
    font-size: 0.8rem;
    padding: 0.1rem 0.5rem;
    border-radius: 4px;
  }

  .status-done {
    color: #3a7d44;
  }

  .status-pending {
    color: #888;
  }

  .rec-meta {
    color: var(--color-text-light);
    font-size: 0.9rem;
    margin-top: 0.15rem;
  }

  .rating {
    color: #d4a017;
    margin-top: 0.2rem;
    font-size: 0.95rem;
  }

  .comment {
    color: var(--color-text-light);
    font-size: 0.9rem;
    margin-top: 0.25rem;
    font-style: italic;
  }

  blockquote {
    font-size: 1.05rem;
    line-height: 1.6;
    margin: 0;
  }

  .quote-author {
    color: var(--color-text-light);
    font-size: 0.9rem;
    margin-top: 0.3rem;
  }

  .quote-item {
    padding-left: 1rem;
    border-left: 2px solid var(--color-border);
  }
</style>
