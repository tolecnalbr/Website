---
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const links = [
  { href: `${base}blog`, label: 'Posts' },
  { href: `${base}recommendations`, label: 'Recommendations' },
  { href: `${base}about`, label: 'About' },
];

// Status: "alive" | "missing" | "dead"
const status = "alive";

const statusConfig = {
  alive: { label: "lancelot is alive", color: "#3a7d44" },
  missing: { label: "haven't heard from him in a few days, anyone?", color: "#c48820" },
  dead: { label: "he's gone. rip.", color: "#c44040" },
};

const current = statusConfig[status];
---

<nav>
  <div class="nav-inner container">
    <div class="nav-left">
      <a href={base} class="nav-logo">lancelot</a>
      <span class="status-tag" style={`--status-color: ${current.color}`}>{current.label}</span>
    </div>
    <ul class="nav-links">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class:list={[{ active: currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) }]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  nav {
    padding: 1.5rem 0;
    background-color: #f2f2f2;
  }

  .nav-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .nav-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .nav-logo {
    font-weight: 600;
    font-size: 1.1rem;
    text-decoration: none;
  }

  .status-tag {
    font-size: 0.7rem;
    padding: 0.15rem 0.5rem;
    border-radius: 10px;
    background-color: var(--status-color);
    color: white;
    white-space: nowrap;
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 1.5rem;
  }

  .nav-links a {
    text-decoration: none;
    font-size: 0.95rem;
    color: var(--color-text-light);
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: var(--color-text);
  }

  @media (max-width: 480px) {
    .nav-inner {
      flex-direction: column;
      gap: 0.75rem;
    }

    .nav-left {
      flex-direction: column;
      gap: 0.4rem;
    }

    .nav-links {
      gap: 1rem;
    }
  }
</style>
